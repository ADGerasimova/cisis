# === CISIS — Переменные окружения ===
# Скопируй этот файл как .env и заполни своими значениями:
#   cp .env.example .env
#
# ВАЖНО: файл .env НЕ попадает в Git (указан в .gitignore)

# Секретный ключ Django (сгенерируй случайную строку)
SECRET_KEY=замени-на-свой-ключ

# Режим отладки (True — локальная разработка, False — сервер)
DEBUG=True

# Разрешённые хосты (через запятую, без пробелов)
ALLOWED_HOSTS=localhost,127.0.0.1

# --- База данных PostgreSQL ---
DB_NAME=CISIS
DB_USER=postgres
DB_PASSWORD=замени-на-свой-пароль
DB_HOST=localhost
DB_PORT=5432

# --- Медиафайлы ---
# Путь к папке с файлами лабораторий
# Windows:  D:\CISIS_Files\Выходные данные лабораторий
# Linux:    /opt/cisis/media
MEDIA_ROOT=
